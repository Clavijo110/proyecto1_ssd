# Base de datos PostgreSQL (Render o local)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd

# Clave para encriptación de datos sensibles (base64, 44 caracteres)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=tu_clave_fernet_aqui

# Opcional: límite de peticiones por minuto
# RATE_LIMIT=60/minute
